{
    "typeAcquisition": {
        "include": ["@types/chrome"]
    },
    "compilerOptions": {
        "esModuleInterop": true,
        "allowJs": true,
        "strict": true,
        "target": "ES2022",
        "moduleResolution": "NodeNext",
        //https://github.com/colinhacks/zod/issues/2260#issuecomment-1709531677
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "module": "ESNext"
    }
}
